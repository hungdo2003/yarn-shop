{
  "name": "yarn-shop-backend",
  "version": "1.0.0",
  "description": "Backend API for Yarn & Handmade Products Shop",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:sync": "node src/config/syncDb.js",
    "db:sync:fresh": "node src/config/syncDb.js --force",
    "db:seed": "node src/config/seed.js",
